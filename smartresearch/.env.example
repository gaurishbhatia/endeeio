# ─── Google Gemini ────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Endee Vector Database ────────────────────────────────────────────────────
# Leave as-is if running locally via Docker (docker compose up -d)
ENDEE_BASE_URL=http://localhost:8080/api/v1
# Set only if you configured NDD_AUTH_TOKEN in docker-compose.yml
ENDEE_AUTH_TOKEN=

# ─── Application Settings ─────────────────────────────────────────────────────
ENDEE_INDEX_NAME=smartresearch_docs
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
